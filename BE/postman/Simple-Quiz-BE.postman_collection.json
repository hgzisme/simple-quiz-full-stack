{
  "info": {
    "_postman_id": "f8a4bf90-5bcb-4a75-aaf0-5ebf9f430002",
    "name": "Simple Quiz BE",
    "description": "Complete backend API collection for simple-quiz-full-stack. Auth requests auto-store token and IDs for protected endpoint testing.",
